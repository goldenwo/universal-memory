#!/usr/bin/env node
// um-bridge-claude-mem — one-way ingest from ~/.claude-mem/claude-mem.db → UM vault
// Spec: docs/plans/2026-04-24-v0.6-design.md §4.3 + §4.3.0
// Security: §6.1 N2 (path-traversal guard on --db-path)
//
// Exit codes (§5.2 / B.1 stable codes):
//   0  success / silent skip (missing DB, cursor-reset done)
//   1  CLI error (path validation failure, unexpected exception)
//   3  SERVER_INTERNAL (schema mismatch)
//   4  STATE_LOCK_CONTENTION (SQLITE_BUSY after retries)

// Note: 'better-sqlite3' is loaded via dynamic import only when the DB is
// actually needed (i.e., after --cursor-reset / --help early exits). This lets
// --cursor-reset and --help work even when better-sqlite3 is not yet installed
// (e.g., before the first `npm install` on a new dev box). D.9 (install-plugin)
// will ensure better-sqlite3 is built before the daemon is started.
import { realpathSync, lstatSync, unlinkSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import { homedir } from 'node:os';
import { parseArgs } from 'node:util';

// D.9 note: translateRows is imported from the helper extracted in D.5.
// bridge-contract is imported inside translate.mjs via relative path (works in
// dev/CI because the repo is a single tree). D.9 (install-plugin-cc.sh) will
// vendor-copy server/lib/bridge-contract.mjs alongside this file.
import { translateRows } from './translate.mjs';

// V1 correction: default DB filename is claude-mem.db (not sessions.db)
const DEFAULT_DB = join(homedir(), '.claude-mem', 'claude-mem.db');

// Schema versions supported by this bridge build.
// V1 fixture PRAGMA user_version = 2 (confirmed empirically).
// Future claude-mem versions will extend this array.
const SUPPORTED_SCHEMA_RANGE = [2];

// ---------------------------------------------------------------------------
// Path-traversal + UNC + symlink-escape guard (§6.1 N2).
//
// A prior substring check on '..' was insufficient — it missed absolute paths
// like /etc/shadow and Windows UNC like \\attacker\share (NTLM hash leak).
// Round-2 adversarial catch: realpathSync on `~/.claude-mem` ALSO canonicalizes
// through symlinks, so an attacker with write access to $HOME could replace
// `~/.claude-mem` itself with a symlink to `/tmp/evil/`; the allowlist then
// computes to `/tmp/evil/`, trivially bypassed. Mitigation: compute allowlist
// from `realpathSync(homedir()) + '/.claude-mem'` WITHOUT realpath'ing the
// .claude-mem component, AND lstat that component — reject if symlink. This
// matches the threat model: if attacker has write to HOME itself they can
// also replace DB file contents (game over anyway), so realpath'ing HOME is
// acceptable; tightening ends at the leaf-most trusted component.
// ---------------------------------------------------------------------------
function validateDbPath(p) {
  if (p.includes('\0')) throw new Error('invalid db-path (null byte)');
  // Reject UNC paths — Windows \\server\share leaks NTLM hashes; POSIX //host
  // is similarly surprising
  if (/^\\\\/.test(p) || /^\/\//.test(p)) throw new Error('invalid db-path (UNC)');

  let resolved;
  try {
    resolved = realpathSync(p);
  } catch (e) {
    if (e.code === 'ENOENT') {
      // Missing DB is handled downstream silently — return original path so
      // the ENOENT check below can fire cleanly
      return p;
    }
    throw e;
  }

  const homeReal = realpathSync(homedir());
  // Build allowlist: the canonical home + '/.claude-mem' WITHOUT resolving
  // .claude-mem itself (so a symlink attack on .claude-mem is caught below)
  const sep = process.platform === 'win32' ? '\\' : '/';
  const cmDir = homeReal + sep + '.claude-mem';

  // lstat .claude-mem and reject if it is a symlink (adversarial R2 finding)
  try {
    const st = lstatSync(cmDir);
    if (st.isSymbolicLink()) {
      throw new Error('invalid db-path (~/.claude-mem is a symlink; refuse to follow)');
    }
  } catch (e) {
    if (e.code !== 'ENOENT') throw e;
    // .claude-mem doesn't exist yet — allowlist the path anyway; the ENOENT
    // check below will fire if the file itself is missing
  }

  const allowlist = [cmDir];

  // Add the repo test-fixtures dir to the allowlist (CWD-independent path via
  // import.meta.url so tests work regardless of where the CLI is invoked from)
  try {
    const repoFixturesUrl = new URL('../../../../../server/test/fixtures', import.meta.url);
    // Convert file URL pathname /E:/Projects/... to E:/Projects/... on Windows
    const fixturesPath = repoFixturesUrl.pathname.replace(/^\/([A-Za-z]):\//, '$1:/');
    allowlist.push(realpathSync(fixturesPath));
  } catch {
    // Fixtures dir may not exist in production installs — safe to ignore
  }

  if (!allowlist.some((root) => resolved === root || resolved.startsWith(root + sep))) {
    throw new Error(`invalid db-path (outside allowlist): ${resolved}`);
  }
  return resolved;
}

async function main() {
  const { values } = parseArgs({
    options: {
      once: { type: 'boolean', default: false },
      'db-path': { type: 'string' },
      'cursor-reset': { type: 'boolean', default: false },
      help: { type: 'boolean', default: false },
    },
  });

  if (values.help) {
    console.log([
      'um-bridge-claude-mem — ingest claude-mem sessions into UM vault',
      '',
      'Usage: um-bridge-claude-mem [options]',
      '',
      'Options:',
      '  --once           Run once and exit (default: continuous daemon)',
      '  --db-path=PATH   Override default DB path (~/.claude-mem/claude-mem.db)',
      '  --cursor-reset   Delete the cursor file and exit (next run re-ingests from beginning)',
      '  --help           Show this help',
      '',
      `Supported claude-mem schema versions: ${SUPPORTED_SCHEMA_RANGE.join(', ')}`,
    ].join('\n'));
    process.exit(0);
  }

  // --cursor-reset: delete cursor file BEFORE opening DB (exit 0)
  if (values['cursor-reset']) {
    const vaultDir = process.env.UM_VAULT_DIR || join(homedir(), '.local', 'share', 'universal-memory');
    const cursorPath = join(vaultDir, '.local', 'bridges', 'claude-mem.json');
    if (existsSync(cursorPath)) {
      try {
        unlinkSync(cursorPath);
      } catch (e) {
        console.error(`[um-bridge] failed to delete cursor file: ${e.message}`);
        process.exit(1);
      }
    }
    console.log('[um-bridge] cursor reset; next run will re-ingest from beginning');
    process.exit(0);
  }

  const rawPath = values['db-path'] || DEFAULT_DB;

  // Validate path — exits 1 on violation
  let dbPath;
  try {
    dbPath = validateDbPath(rawPath);
  } catch (e) {
    console.error(`[um-bridge] ${e.message}`);
    process.exit(1);
  }

  // Missing claude-mem DB: exit 0 silently (matches install-plugin-codex pattern).
  // existsSync is O(1) instead of reading the whole DB into memory.
  if (!existsSync(dbPath)) {
    // claude-mem not installed or DB not yet created — not an error
    process.exit(0);
  }

  // §4.3.0 point 8 — upstream-locked retry: 3× with 1 s backoff on SQLITE_BUSY
  // Dynamic import: deferred until here so --cursor-reset / --help can run
  // without better-sqlite3 being installed (the module-load error would fire
  // before main() could even parse flags otherwise).
  let Database;
  try {
    ({ default: Database } = await import('better-sqlite3'));
  } catch (e) {
    console.error('[um-bridge] better-sqlite3 not found — run: npm install (in plugins/claude-code/universal-memory/bin/)');
    process.exit(1);
  }
  let db;
  for (let attempt = 0; attempt < 3; attempt++) {
    try {
      db = new Database(dbPath, { readonly: true, timeout: 1000 });
      break;
    } catch (e) {
      if (
        e.code === 'SQLITE_BUSY' ||
        e.code === 'SQLITE_BUSY_SNAPSHOT' ||
        /locked/i.test(e.message)
      ) {
        if (attempt === 2) {
          console.error(
            '[um-bridge] claude-mem DB locked after 3 retries; exiting STATE_LOCK_CONTENTION'
          );
          process.exit(4); // STATE_LOCK_CONTENTION
        }
        await new Promise((r) => setTimeout(r, 1000));
        continue;
      }
      // Unexpected open error
      console.error(`[um-bridge] failed to open DB: ${e.message}`);
      process.exit(1);
    }
  }

  // Validate schema version
  const version = db.pragma('user_version', { simple: true });
  if (!SUPPORTED_SCHEMA_RANGE.includes(version)) {
    console.error(
      `[um-bridge] FAIL: claude-mem schema version ${version} not in supported range ` +
        `${SUPPORTED_SCHEMA_RANGE.join(', ')}; vault not modified; ` +
        'see um-bridge-claude-mem --help for supported versions'
    );
    db.close();
    process.exit(3); // SERVER_INTERNAL
  }

  // ---------------------------------------------------------------------------
  // §4.3 — Read sessions + translate to UM markdown
  //
  // JOIN rationale: the three-table JOIN is needed because the V1 schema
  // splits session metadata (sessions), memory entries (memories), and
  // summarized content (overviews) across three tables. Each joined via
  // sessions.session_id (TEXT, stable external ID).
  //
  // Cursor: we order by created_at_epoch (INTEGER) for stable pagination
  // across restarts. The cursor stores last_ingested_at_epoch from the
  // previous run; on first run the cursor file is absent and the default
  // 0 is used (ingest everything). D.6 will write the cursor after
  // two-phase write completes.
  // ---------------------------------------------------------------------------
  const vaultDir =
    process.env.UM_VAULT_DIR ||
    join(homedir(), '.local', 'share', 'universal-memory');
  const cursorPath = join(vaultDir, '.local', 'bridges', 'claude-mem.json');

  // readCursor is imported in translate.mjs; we import directly here too for
  // the cursor epoch. D.6 will also need writeCursor — add that import then.
  // For D.5 we only need to read the cursor epoch.
  let lastEpoch = 0;
  if (existsSync(cursorPath)) {
    try {
      const { readFile } = await import('node:fs/promises');
      const raw = await readFile(cursorPath, 'utf8');
      const cur = JSON.parse(raw);
      lastEpoch = cur.last_ingested_at_epoch ?? 0;
    } catch {
      // Corrupt cursor — start from beginning (safe; idempotent re-ingest)
      lastEpoch = 0;
    }
  }

  const MAX_PER_RUN = parseInt(process.env.UM_BRIDGE_MAX_PER_RUN || '50', 10);

  // Three-table LEFT JOIN — §4.3 V1 schema
  // Cursor field: created_at_epoch INTEGER (stable across schema versions)
  // Ties broken by session_id ASC (TEXT, deterministic)
  const rows = db
    .prepare(
      `SELECT
         s.id              AS rowid,
         s.session_id      AS session_id,
         s.project         AS project_raw,
         s.created_at      AS created_at,
         s.created_at_epoch AS created_at_epoch,
         m.title           AS title,
         o.content         AS summary
       FROM sessions s
       LEFT JOIN memories m ON m.session_id = s.session_id
       LEFT JOIN overviews o ON o.session_id = s.session_id
       WHERE s.created_at_epoch > ?
       ORDER BY s.created_at_epoch ASC, s.session_id ASC
       LIMIT ?`
    )
    .all(lastEpoch, MAX_PER_RUN);

  db.close();

  const { translated, skipped } = translateRows(rows);

  if (skipped.length > 0) {
    for (const s of skipped) {
      console.warn(`[um-bridge] skipped session ${s.id}: ${s.reason}`);
    }
  }

  console.log(
    `[um-bridge] translated=${translated.length} skipped=${skipped.length} ` +
      `(epoch_cursor=${lastEpoch} limit=${MAX_PER_RUN})`
  );

  // D.6 will take over from here: two-phase write + cursor advance
  // For D.5 the loop ends with translated[] and skipped[] populated.

  if (values.once) {
    // --once: single pass, exit 0
    process.exit(0);
  }

  // Daemon mode: D.6 will add polling interval here
  process.exit(0);
}

await main();
