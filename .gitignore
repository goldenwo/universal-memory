# Environment
.env
.env.local
.env.*.local
.env.bak*
*.env.backup

# Runtime data
server/data/
server/qdrant/

# mem0 import working dir (operator's PERSONAL facts manifest — must never be committed;
# cli/mem0-import.mjs also hard-refuses to write under the repo tree, this is the backstop)
.mem0-import/
server/logs/
data/
*.db
*.db-journal
# Test fixtures (structurally-valid synthetic DBs) are the one exception — keep them tracked
!server/test/fixtures/*.db

# Node
node_modules/
dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/
*.egg-info/

# Build artifacts
build/
out/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.coverage
.pytest_cache/
.mypy_cache/
htmlcov/

# Secrets — never commit
*.pem
*.key
secrets.json
credentials.json

# Internal working docs — not shipped to users
# Files are kept locally for maintainer reference but never tracked.
# History of these was scrubbed via git filter-repo in the past.
docs/plans/
docs/decisions/

# Claude Code local state (session state, reviews, snapshots — never public)
.claude/*

# mktemp scratch dirs created by test scripts (pattern: t<digits>.<alphanum>/)
/t[0-9]*.[A-Za-z0-9]*/

# Visual-companion brainstorm sessions
.superpowers/

# Host-specific compose overrides (compose auto-loads this name for a bare
# `docker compose`). Never shipped — each host pins its own qdrant image,
# port bindings, or bind paths here. Unanchored, so it matches at any depth.
docker-compose.override.yml
