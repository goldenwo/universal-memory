# universal-memory v0.7 — provider-neutral configuration
#
# WARNING: do not use latest-style model aliases (e.g. 'gpt-4o-latest',
# 'gemini-2.0-flash-latest'). Pin a specific dated version (e.g.
# 'gpt-4o-2024-08-06', 'claude-haiku-4-5-20251001') for deterministic
# behavior. Provider-side silent substitutions of "latest" pointers can
# change embedding dimension or summarizer output mid-flight; the spec §10
# R3 mitigation (embedding stamp + startup probe) only catches drift on
# embeddings, not on summarizer/facts. See spec §10 R3.
#
# ─── Required ────────────────────────────────────────────────────────────
# User ID that scopes memories. Use any string; it's the namespace.
# Required — server exits at startup if blank or unset.
MEM0_USER_ID=

# ─── Providers (spec §5.1) ──────────────────────────────────────────────
# Embeddings: openai | google | ollama   (no anthropic — no first-party embeds)
# No cross-provider fallback for embeddings: switching providers requires
# `um-cli reindex` (spec §5.6, §6).
UM_EMBEDDING_PROVIDER=openai
UM_EMBEDDING_MODEL=text-embedding-3-small

# Summarizer: openai | anthropic | google | ollama
# Cross-provider fallback OK; honor existing v0.6 behavior.
UM_SUMMARIZER_PROVIDER=openai
UM_SUMMARIZER_MODEL=gpt-4o-mini
# Optional fallback provider, same enum as UM_SUMMARIZER_PROVIDER.
UM_SUMMARIZER_FALLBACK=

# Fact-extraction LLM (powers /api/add, memory_add):
# openai | anthropic | google | ollama
UM_FACTS_PROVIDER=openai
UM_FACTS_MODEL=gpt-4.1-nano-2025-04-14
# Optional fallback provider (NEW vs v0.6 — opt-in cross-provider fallback).
UM_FACTS_FALLBACK=

# ─── API keys (set what you use; UM_-prefixed overrides global) ─────────
# Resolution rule: UM_<P>_API_KEY || <P>_API_KEY (spec §5.2). UM-specific
# override wins; global standard name is the fallback. Google additionally
# accepts GEMINI_API_KEY (their docs use both).
OPENAI_API_KEY=
# UM_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# UM_ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# UM_GOOGLE_API_KEY=
# Ollama is self-hosted; reachability probed at startup.
OLLAMA_HOST=http://localhost:11434

# ─── Image / version pin (v1.0 dual-mode compose) ───────────────────────
# By default `docker compose up -d` pulls
# ghcr.io/goldenwo/universal-memory-server:latest. To pin a specific
# release in production, uncomment and set UM_VERSION (release.yml emits
# semver tags: 1.0.0, 1.0, latest; prereleases skip latest).
# UM_VERSION=1.0.0
#
# UM_IMAGE escape hatch — set the full image ref directly. Takes precedence
# over UM_VERSION. Useful for private mirrors or local-tag dev workflows.
# UM_IMAGE=registry.example.com/universal-memory-server:1.0.0
#
# For local source-build (development against uncommitted changes), set
# UM_BUILD_LOCAL=1 here and re-run install.sh — it forwards the build
# override file automatically. Or invoke compose manually:
#   docker compose -f docker-compose.yml -f docker-compose.build.yml up -d
#
# Note: UM_BUILD_LOCAL=1 ignores UM_IMAGE — the build override pins the
# local image tag to `universal-memory-server:local`. To use a private
# mirror or pinned external tag, leave UM_BUILD_LOCAL unset and set
# UM_IMAGE instead. Restructure to UM_IMAGE_SOURCE={pull,build} is a
# v1.1 polish item.

# ─── Server tuning ───────────────────────────────────────────────────────
# Port the HTTP server binds to. Container-internal. Exposed via compose.
MEM0_MCP_PORT=6335

# Qdrant connection (internal to docker network — usually no need to change)
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_COLLECTION=memories

# Mem0 history DB (SQLite) path. Default is /tmp/mem0-history.db — ephemeral,
# cleared on container restart. For persistent edit/dedup history, set this to
# a path inside a bind-mounted directory AND uncomment the matching volume
# mount in docker-compose.yml. Suggested setup:
#   - bind ./data/mem0-history → /var/lib/mem0   (compose volume entry)
#   - MEM0_HISTORY_DB_PATH=/var/lib/mem0/history.db   (this var)
# MEM0_HISTORY_DB_PATH=/var/lib/mem0/history.db

# ─── Vault (session-continuity summaries) ────────────────────────────────
# Host path to the vault directory. Required — no default (Windows ${HOME}
# does not interpolate in compose). Set this before running docker compose up.
# The install wizard (Task 5.5) sets this automatically.
UM_VAULT_DIR=

# Mount mode for the vault volume. Defaults to ro (read-only).
# Set to rw only when MCP write tools are enabled (UM_MCP_WRITE_ENABLED=true,
# see Task 10). Install wizard sets both consistently.
UM_MOUNT_MODE=ro

# ─── MCP write tools ─────────────────────────────────────────────────────
# Enable MCP write tools: memory_capture, memory_forget, memory_supersede.
# Required for Claude.ai / Claude Desktop to write to the vault — those
# clients cannot write to the host filesystem directly, so the server is
# their write path.
# Default off — the vault stays read-only to the server unless you opt in.
# When enabling, also set UM_MOUNT_MODE=rw so docker-compose mounts rw.
#
# Security: writes are protected by bearer auth (v0.6+). install.sh
# auto-generates the token at ~/.um/auth-token (chmod 600). Loopback
# connections without proxy headers bypass auth by default per
# UM_ALLOW_LOOPBACK_NOAUTH=true; set false to require the token from
# loopback too. See docs/mcp-tools.md "Security" for full posture.
UM_MCP_WRITE_ENABLED=false

# ─── Temporal decay (optional) ───────────────────────────────────────────
# Enable time-based memory decay weighting. Defaults to false.
UM_TEMPORAL_DECAY=false

# Half-life for decay in days. Only used when UM_TEMPORAL_DECAY=true.
UM_DECAY_HALF_LIFE_DAYS=30

# ─── Rate limiter — reverse proxy support (v1.0 W6.4 nice-to-have) ───────
# By default the rate limiter keys on req.socket.remoteAddress. Behind a
# reverse proxy (Cloudflare Tunnel, nginx, Tailscale Funnel) every request
# appears from the proxy IP — making rate limits trivially bypassable by
# any client sharing the proxy. To rate-limit by the real client:
#
#   UM_RATE_LIMIT_TRUSTED_PROXY_HEADER=x-forwarded-for
#
# When set, the limiter takes the leftmost IP from the named header (RFC
# 7239 convention). Only enable when EVERY untrusted network path is
# rejected at the proxy — otherwise clients spoof the header to evade
# limits. Default unset = direct-connection-safe.
# UM_RATE_LIMIT_TRUSTED_PROXY_HEADER=

# ─── D1 cross-surface fact dedup (v1.1 — flag-gated; default OFF) ────────
# When true, every server-side write through umAdd() runs a two-layer dedup
# check (content-hash + embedding-similarity) under the caller's userId before
# upserting. Near-duplicates collapse onto a single qdrant point with the
# union of `surfaces` and `projects` Sets and incremented `dedupCount`.
#
# This PR ships flag-OFF so the landing is non-destructive. The flag-flip
# PR will land after the threshold-tuning eval (see docs/architecture/dedup.md
# when added) and operator observation of `um_dedup_total{result='hit'}` rate.
#
# See: docs/plans/2026-05-09-d1-spec.md (gitignored maintainer doc) for the
# full design, decision points, risk register, and rollout plan.
UM_DEDUP_ENABLED=false

# Cosine similarity threshold for the Layer 2 (embedding-similarity) dedup
# layer. Default 0.84 derived from a 50-pair labeled eval against
# text-embedding-3-small (F_0.5=0.77 at τ=0.84, plateau midpoint of an
# 8-τ band where precision saturates at 1.0). See docs/architecture/dedup.md
# for methodology, fixture composition, and re-run instructions.
# Has no effect when UM_DEDUP_ENABLED=false.
UM_DEDUP_EMBEDDING_THRESHOLD=0.84
