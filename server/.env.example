# universal-memory v0.7 — provider-neutral configuration
#
# WARNING: do not use latest-style model aliases (e.g. 'gpt-4o-latest',
# 'gemini-2.0-flash-latest'). Pin a specific dated version (e.g.
# 'gpt-4o-2024-08-06', 'claude-haiku-4-5-20251001') for deterministic
# behavior. Provider-side silent substitutions of "latest" pointers can
# change embedding dimension or summarizer output mid-flight; the spec §10
# R3 mitigation (embedding stamp + startup probe) only catches drift on
# embeddings, not on summarizer/facts. See spec §10 R3.
#
# ─── Required ────────────────────────────────────────────────────────────
# User ID that scopes memories. Use any string; it's the namespace.
# Required — server exits at startup if blank or unset.
MEM0_USER_ID=

# ─── Providers (spec §5.1) ──────────────────────────────────────────────
# Embeddings: openai | google | ollama   (no anthropic — no first-party embeds)
# No cross-provider fallback for embeddings: switching providers requires
# `um-cli reindex` (spec §5.6, §6).
UM_EMBEDDING_PROVIDER=openai
UM_EMBEDDING_MODEL=text-embedding-3-small

# Summarizer: openai | anthropic | google | ollama
# Cross-provider fallback OK; honor existing v0.6 behavior.
UM_SUMMARIZER_PROVIDER=openai
UM_SUMMARIZER_MODEL=gpt-4o-mini
# Optional fallback provider, same enum as UM_SUMMARIZER_PROVIDER.
UM_SUMMARIZER_FALLBACK=

# Fact-extraction LLM (powers /api/add, memory_add):
# openai | anthropic | google | ollama
UM_FACTS_PROVIDER=openai
UM_FACTS_MODEL=gpt-4.1-nano-2025-04-14
# Optional fallback provider (NEW vs v0.6 — opt-in cross-provider fallback).
UM_FACTS_FALLBACK=

# ─── API keys (set what you use; UM_-prefixed overrides global) ─────────
# Resolution rule: UM_<P>_API_KEY || <P>_API_KEY (spec §5.2). UM-specific
# override wins; global standard name is the fallback. Google additionally
# accepts GEMINI_API_KEY (their docs use both).
OPENAI_API_KEY=
# UM_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# UM_ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# UM_GOOGLE_API_KEY=
# Ollama is self-hosted; reachability probed at startup.
OLLAMA_HOST=http://localhost:11434

# ─── Image / version pin (v1.0 dual-mode compose) ───────────────────────
# By default `docker compose up -d` pulls
# ghcr.io/goldenwo/universal-memory-server:latest. To pin a specific
# release in production, uncomment and set UM_VERSION (release.yml emits
# semver tags: 1.0.0, 1.0, latest; prereleases skip latest).
# UM_VERSION=1.0.0
#
# UM_IMAGE escape hatch — set the full image ref directly. Takes precedence
# over UM_VERSION. Useful for private mirrors or local-tag dev workflows.
# UM_IMAGE=registry.example.com/universal-memory-server:1.0.0
#
# For local source-build (development against uncommitted changes), set
# UM_BUILD_LOCAL=1 here and re-run install.sh — it forwards the build
# override file automatically. Or invoke compose manually:
#   docker compose -f docker-compose.yml -f docker-compose.build.yml up -d
#
# Note: UM_BUILD_LOCAL=1 ignores UM_IMAGE — the build override pins the
# local image tag to `universal-memory-server:local`. To use a private
# mirror or pinned external tag, leave UM_BUILD_LOCAL unset and set
# UM_IMAGE instead. Restructure to UM_IMAGE_SOURCE={pull,build} is a
# v1.1 polish item.

# ─── Server tuning ───────────────────────────────────────────────────────
# Port the HTTP server binds to. Container-internal. Exposed via compose.
MEM0_MCP_PORT=6335

# Qdrant connection (internal to docker network — usually no need to change)
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_COLLECTION=memories

# Mem0 history DB (SQLite) path. Default is /tmp/mem0-history.db — ephemeral,
# cleared on container restart. For persistent edit/dedup history, set this to
# a path inside a bind-mounted directory AND uncomment the matching volume
# mount in docker-compose.yml. Suggested setup:
#   - bind ./data/mem0-history → /var/lib/mem0   (compose volume entry)
#   - MEM0_HISTORY_DB_PATH=/var/lib/mem0/history.db   (this var)
# MEM0_HISTORY_DB_PATH=/var/lib/mem0/history.db

# ─── Vault (session-continuity summaries) ────────────────────────────────
# Host path to the vault directory. Required — no default (Windows ${HOME}
# does not interpolate in compose). Set this before running docker compose up.
# The install wizard (Task 5.5) sets this automatically.
UM_VAULT_DIR=

# Mount mode for the vault volume. Defaults to ro (read-only).
# Set to rw only when MCP write tools are enabled (UM_MCP_WRITE_ENABLED=true,
# see Task 10). Install wizard sets both consistently.
UM_MOUNT_MODE=ro

# ─── MCP write tools ─────────────────────────────────────────────────────
# Enable MCP write tools: memory_capture, memory_forget, memory_supersede.
# Required for Claude.ai / Claude Desktop to write to the vault — those
# clients cannot write to the host filesystem directly, so the server is
# their write path.
# Default off — the vault stays read-only to the server unless you opt in.
# When enabling, also set UM_MOUNT_MODE=rw so docker-compose mounts rw.
#
# Security: writes are protected by bearer auth (v0.6+). install.sh
# auto-generates the token at ~/.um/auth-token (chmod 600). Loopback
# connections without proxy headers bypass auth by default per
# UM_ALLOW_LOOPBACK_NOAUTH=true; set false to require the token from
# loopback too. See docs/mcp-tools.md "Security" for full posture.
UM_MCP_WRITE_ENABLED=false

# ─── Temporal decay (optional) ───────────────────────────────────────────
# Enable time-based memory decay weighting. Defaults to false.
UM_TEMPORAL_DECAY=false

# Half-life for decay in days. Only used when UM_TEMPORAL_DECAY=true.
UM_DECAY_HALF_LIFE_DAYS=30

# ─── Rate limiter — reverse proxy support (v1.0 W6.4 nice-to-have) ───────
# By default the rate limiter keys on req.socket.remoteAddress. Behind a
# reverse proxy (Cloudflare Tunnel, nginx, Tailscale Funnel) every request
# appears from the proxy IP — making rate limits trivially bypassable by
# any client sharing the proxy. To rate-limit by the real client:
#
#   UM_RATE_LIMIT_TRUSTED_PROXY_HEADER=x-forwarded-for
#
# When set, the limiter takes the leftmost IP from the named header (RFC
# 7239 convention). Only enable when EVERY untrusted network path is
# rejected at the proxy — otherwise clients spoof the header to evade
# limits. Default unset = direct-connection-safe.
# UM_RATE_LIMIT_TRUSTED_PROXY_HEADER=

# ─── F1 project-soft-default unification (v1.1) ─────────────────────────
# When a write tool (memory_capture, memory_add, memory_append_turn,
# memory_checkpoint) is called without a `metadata.project` / `project`
# slug, the server falls back to this value rather than (a) hardcoding
# the literal "default", (b) silently dropping the project dimension, or
# (c) hard-failing — the three pre-F1 behaviors the A1 audit
# (docs/audits/2026-05-08-cross-surface-defaults.md §F1) identified as
# heterogeneous.
#
# Read tools (memory_state, memory_recent) intentionally keep their
# hard-fail — an ambiguous-project read returning fallback data would be
# more surprising than the error. memory_search remains project-optional
# (post-filter; missing project searches across all).
#
# Must match the project slug pattern /^[a-zA-Z0-9._-]+$/. An invalid
# value is ignored at runtime and the server falls back to the literal
# "default" + a one-shot warn log.
UM_DEFAULT_PROJECT=default

# ─── D2 lane / persona schema (v1.1) ────────────────────────────────────
# Optional additive metadata partitions on writes (memory_add /
# memory_capture / REST /api/add) and read filters on memory_search /
# REST POST /api/search. Validated against PROJECT_SLUG_RE. No env var
# here — lane and persona ship coherent from day one (no historical
# heterogeneity to unify, no soft-default needed). Omitted = unpartitioned.
# See docs/mcp-tools.md "Lane / persona schema (v1.1 D2)" for the full
# contract and operator-visible read-filter semantics on pre-D2 points.

# ─── D1 cross-surface fact dedup (v1.1 — default ON since flag-flip PR) ──
# Every server-side write through umAdd() runs a two-layer dedup check
# (content-hash + embedding-similarity) under the caller's userId before
# upserting. Near-duplicates collapse onto a single qdrant point with the
# union of `surfaces` and `projects` Sets and incremented `dedupCount`.
#
# Default ON since v1.1. Set UM_DEDUP_ENABLED=false to opt out (the only
# value that disables — anything else, including unset/empty, keeps it on).
# Threshold (UM_DEDUP_EMBEDDING_THRESHOLD below) is the empirical default
# from the 50-pair eval on text-embedding-3-small.
#
# See: docs/architecture/dedup.md for design, methodology, and rollout.
UM_DEDUP_ENABLED=true

# Cosine similarity threshold for the Layer 2 (embedding-similarity) dedup
# layer. Default 0.84 derived from a 50-pair labeled eval against
# text-embedding-3-small (F_0.5=0.77 at τ=0.84, plateau midpoint of an
# 8-τ band where precision saturates at 1.0). See docs/architecture/dedup.md
# for methodology, fixture composition, and re-run instructions.
# Has no effect when UM_DEDUP_ENABLED=false.
UM_DEDUP_EMBEDDING_THRESHOLD=0.84

# ─── D3.2 auto-supersession contradiction detector (v1.2 — default ON) ───────
# At session-end, memory_checkpoint runs a contradiction detector over the
# just-summarised transcript and marks older conflicting facts status:'superseded'
# (reversible via memory_supersede {action:'unsupersede', id}). Detection only
# runs for partitioned buckets (lane and/or persona set on the checkpoint call);
# unpartitioned (no lane, no persona) buckets are ineligible by design (R1-B1).
#
# POLARITY NOTE (v1.2 flip, D3.3): UM_AUTOSUPERSEDE_ENABLED is ON BY DEFAULT —
# opt-out polarity, identical to UM_DEDUP_ENABLED. Only the literal lowercase
# string 'false' disables it; unset / empty / any other value keeps it ON.
# (Through v1.1 this was strict-'true' opt-in / default OFF; the D3.3 eval
# validated the detector at precision 1.0, and the v1.2 flip turned it on.)
# Even ON, the detector only acts on partitioned (lane/persona) checkpoints —
# unpartitioned buckets are ineligible by design (R1-B1), so production stays
# effectively inert until a lane-classifier populates lanes.
#
# See: docs/plans/2026-05-16-d3-lane-scoped-auto-supersession-spec.md for design and rollout.
UM_AUTOSUPERSEDE_ENABLED=true

# LLM provider for the contradiction judge.
# Resolution chain: UM_CONTRADICTION_PROVIDER → UM_SUMMARIZER_PROVIDER → 'openai'
# When unset, the contradiction judge inherits the summarizer provider.
# Supported values: openai | anthropic | google | ollama
#UM_CONTRADICTION_PROVIDER=openai

# Model for the contradiction judge.
# Resolution chain: UM_CONTRADICTION_MODEL → the RESOLVED contradiction
# provider's own default model (e.g. gpt-4o-mini for openai). The model is
# always resolved against the CONTRADICTION provider — never against a different
# provider's default (R3-G1, avoids cross-provider model-name bleed).
# Has no effect when UM_AUTOSUPERSEDE_ENABLED=false (detector disabled).
#UM_CONTRADICTION_MODEL=gpt-4o-mini

# Minimum LLM-JUDGE CONFIDENCE (0..1) required to supersede an older fact.
# Default 0.80 (eval-derived: server/eval/results/d3-latest.json — judge precision
# 1.0 / recall 1.0 across 2 runs at 0.80). The eval found zero false positives at
# every threshold, so the mechanical precision-floor rule recommends 0.70; 0.80 is
# a deliberate conservative pin (top of the common recall=1.0 plateau, rejects
# hedged sub-0.80 verdicts). Lower values increase recall (more
# supersessions) at the cost of precision (more false positives). This is the
# JUDGE cutoff only — the candidate-retrieval cosine cutoff is a SEPARATE knob
# (UM_AUTOSUPERSEDE_RETRIEVAL_THRESHOLD below). Has no effect when
# UM_AUTOSUPERSEDE_ENABLED=false (detector disabled).
#UM_AUTOSUPERSEDE_THRESHOLD=0.80

# Minimum EMBEDDING COSINE (0..1) for an older fact to be RETRIEVED as a
# contradiction candidate (the qdrant score_threshold). Default 0.45 (eval-derived).
# Kept FAR BELOW the judge cutoff because true contradictions are only moderately
# cosine-similar (eval: true-contradiction cosines span 0.50–0.87 — all below the
# judge τ); a high value here would retrieve none of them and the judge would never
# see the candidate. Has no effect when UM_AUTOSUPERSEDE_ENABLED=false (detector disabled).
#UM_AUTOSUPERSEDE_RETRIEVAL_THRESHOLD=0.45

# Upper cosine edge of the contradiction-overlap band for WRITE-TIME in-band
# supersession (Gap-5 P3 / ADR-0007 Option C). When a /api/add write is
# supersede-eligible (autosupersede ON + the partition carries a lane/persona)
# AND its dedup embedding-hit cosine is in [UM_DEDUP_EMBEDDING_THRESHOLD, this],
# an inline judge decides whether the "duplicate" is actually a CONTRADICTION; if
# so the newer fact is kept (status:current) and the older is demoted, instead of
# the default keep-older dedup merge. A hit ABOVE this ceiling is too similar to be
# a contradiction → keep-older. This is a COST bound (how often the judge fires),
# NOT a correctness gate — the judge (UM_AUTOSUPERSEDE_THRESHOLD) is the precision
# gate. Default 0.87 = top of the measured contradiction cosine span (D3.3 eval,
# same embedder); re-eval if the embedding model changes. Keep in lockstep with
# contradictionBandCeiling() in server/lib/supersede.mjs + its drift test. Has no
# effect when UM_AUTOSUPERSEDE_ENABLED=false.
#UM_CONTRADICTION_BAND_CEILING=0.87

# ─── Gap-5 lane classifier (v1.3 — ACTIVE by default; opt-out) ──
# Opt-out, mirroring UM_DEDUP_ENABLED / UM_AUTOSUPERSEDE_ENABLED: unset / empty / any
# value except 'false' → ACTIVE (classify each write into a lane); the literal 'false'
# (whitespace-trimmed) → off. v1.3 flipped this from the v1.2 strict-'true' inert opt-in;
# the prior shadow ENV value is removed (shadow is now a test seam only). Auto-classified
# lanes WAKE the D3 auto-supersession detector — set 'false' to keep lanes caller-only and
# auto-supersession inert (see MIGRATION.md v1.2 → v1.3).
# UM_LANE_CLASSIFIER_ENABLED=false               # uncomment to OPT OUT of lane auto-classification
# UM_LANE_TAXONOMY_PATH=/path/to/taxonomy.json   # override the bundled starter taxonomy (server/config/lane-taxonomy.default.json)
# UM_LANE_CLASSIFIER_THRESHOLD=0.30              # cosine τ_lane; pinned 2026-06-07, re-validated 2026-06-08 on the de-leaked + held-out 106-row fixture: 0.962 precision / 0.797 recall ≥ 0.95 floor
# UM_LANE_CLASSIFIER_MARGIN=0.08                 # top1-top2 ambiguity margin; pinned WITH τ (load-bearing — at margin 0 no τ clears the floor)
# UM_LANE_CLASSIFIER_TOPK=3                       # multi-prototype: score each lane by the MEAN of its top-K nearest exemplar cosines (K=1 → nearest-exemplar; large K → single-centroid). 3 pinned by the eval.
